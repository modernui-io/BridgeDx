# ── INFERENCE BACKEND ─────────────────────────────────────────────────
# "vertex"  → Google Vertex AI (requires GOOGLE_CLOUD_PROJECT)
# "local"   → Ollama on localhost:11434 (requires Ollama running)
INFERENCE_BACKEND=vertex

# ── GOOGLE VERTEX AI (only needed if INFERENCE_BACKEND=vertex) ────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1
MEDGEMMA_4B_MODEL=medgemma-1.5-4b-it
MEDGEMMA_27B_MODEL=medgemma-27b-text-it

# ── OLLAMA (only needed if INFERENCE_BACKEND=local) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_4B_MODEL=MedAIBase/MedGemma1.5:4b
OLLAMA_27B_MODEL=MedAIBase/MedGemma1.5:4b

# ── MINIO ─────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=bridgedx
MINIO_SECRET_KEY=bridgedx_secret_dev
MINIO_USE_SSL=false
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_EXPORTS=exports

# ── DATABASE ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/bridgedx.db

# ── RAG ───────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
BM25_PATH=./data/bm25/index.pkl
PARENT_STORE_PATH=./data/parents
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

RAG_CHILD_CHUNK_SIZE=300
RAG_PARENT_CHUNK_SIZE=900
RAG_CHILD_OVERLAP=50
RAG_BM25_TOP_K=10
RAG_VECTOR_TOP_K=10
RAG_RERANK_TOP_K=6
RAG_HYBRID_ALPHA=0.5

# ── SAFETY ────────────────────────────────────────────────────────────
CONFIDENCE_LOW_THRESHOLD=0.40
CONFIDENCE_HIGH_THRESHOLD=0.70
MAX_UPLOAD_SIZE_MB=10
PRESIGNED_URL_EXPIRY_SECONDS=3600

# ── APP ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5174
LOG_LEVEL=INFO
